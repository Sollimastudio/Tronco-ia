# API Keys - Deixe vazio se não for usar
# Você pode usar um ou mais dos serviços abaixo
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Configurações do Banco de Dados
DATABASE_PATH=./data/tronco.db

# Configurações do Servidor
HOST=0.0.0.0
PORT=8000

# Modelo padrão de IA (usado quando não especificado)
DEFAULT_AI_MODEL=gemini

# Modelos padrão por provider (opcional)
OPENAI_DEFAULT_MODEL=gpt-3.5-turbo
GEMINI_DEFAULT_MODEL=gemini-pro
OLLAMA_DEFAULT_MODEL=llama2

# Configurações de Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Configurações de Upload
MAX_UPLOAD_SIZE=10485760  # 10MB em bytes
UPLOAD_DIR=./uploads
